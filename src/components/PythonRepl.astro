---
interface Props {
  code: string;
  /** Optional unique-ish id for this REPL instance on the page. */
  id?: string;
}
const { code, id = 'pyrepl' } = Astro.props;
const replId = `${id}-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="pyrepl not-content" data-repl-id={replId} data-original={code}>
  <div class="pyrepl__header">
    <div class="pyrepl__btn-group">
      <button class="pyrepl__run" type="button">▶ Run tests</button>
      <button class="pyrepl__reset" type="button" title="Reset to original">↻ Reset</button>
    </div>
    <span class="pyrepl__status" data-status>idle</span>
  </div>
  <div class="pyrepl__editor-host" data-editor></div>
  <pre class="pyrepl__output" data-output>Click <strong>Run tests</strong> to execute. First run downloads Python (~10 MB, cached after that).</pre>
  <div class="pyrepl__timing" data-timing></div>
</div>

<script>
  import { EditorView, keymap, lineNumbers, highlightActiveLine } from '@codemirror/view';
  import { EditorState } from '@codemirror/state';
  import { defaultKeymap, indentWithTab, history, historyKeymap } from '@codemirror/commands';
  import { python, globalCompletion, localCompletionSource } from '@codemirror/lang-python';
  import { oneDark } from '@codemirror/theme-one-dark';
  import {
    syntaxHighlighting,
    defaultHighlightStyle,
    indentOnInput,
    bracketMatching,
    indentUnit,
  } from '@codemirror/language';
  import {
    autocompletion,
    completionKeymap,
    closeBrackets,
    closeBracketsKeymap,
  } from '@codemirror/autocomplete';

  const PYODIDE_VERSION = '0.27.2';
  const PYODIDE_BASE = `https://cdn.jsdelivr.net/pyodide/v${PYODIDE_VERSION}/full/`;

  // Module-scoped: the Pyodide instance is shared across all REPLs on the page.
  let pyodidePromise: Promise<any> | null = null;
  const RUN_TIMEOUT_SECS = 5;

  async function loadPyodideOnce() {
    if (!pyodidePromise) {
      pyodidePromise = (async () => {
        if (!(window as any).loadPyodide) {
          await new Promise<void>((resolve, reject) => {
            const s = document.createElement('script');
            s.src = PYODIDE_BASE + 'pyodide.js';
            s.onload = () => resolve();
            s.onerror = () => reject(new Error('Failed to load pyodide.js'));
            document.head.appendChild(s);
          });
        }
        return await (window as any).loadPyodide({ indexURL: PYODIDE_BASE });
      })();
    }
    return pyodidePromise;
  }

  // Wraps user code in a sys.settrace-based timeout. The trace function is called
  // on every Python line/call, checks the clock every 256 invocations, and raises
  // TimeoutError if the deadline has passed. This is the only reliable way to
  // interrupt a tight Python loop in the browser's main thread.
  async function runPythonTimed(pyodide: any, code: string): Promise<void> {
    pyodide.globals.set('__exec_code__', code);
    try {
      await pyodide.runPythonAsync(`
import sys as _sys, time as _time
_dl = _time.time() + ${RUN_TIMEOUT_SECS}
_n = [0]
def _tr(f, e, a):
    _n[0] += 1
    if _n[0] & 255 == 0 and _time.time() > _dl:
        raise TimeoutError('Timed out after ${RUN_TIMEOUT_SECS}s')
    return _tr
_sys.settrace(_tr)
try:
    exec(compile(__exec_code__, '<exec>', 'exec'), globals())
finally:
    _sys.settrace(None)
`);
    } catch (err: any) {
      const msg: string = err?.message ?? String(err);
      if (msg.includes('TimeoutError') || msg.includes('Timed out')) {
        throw new Error('Timed out after 5s');
      }
      throw err;
    } finally {
      try { pyodide.globals.delete('__exec_code__'); } catch {}
    }
  }

  // CodeMirror theme-injected overrides with the right specificity to beat
  // Starlight's content CSS (which would otherwise add vertical margin to
  // every .cm-line and balloon the gutter line-height).
  const tightLines = EditorView.theme({
    '&': { fontSize: '0.85rem' },
    '.cm-content': {
      lineHeight: '1.4',
      padding: '4px 0',
      fontFamily: 'ui-monospace, SFMono-Regular, Menlo, monospace',
    },
    '.cm-line': {
      lineHeight: '1.4',
      padding: '0 4px',
      margin: '0',
    },
    '.cm-gutters': { borderRight: 'none' },
    '.cm-gutterElement': {
      lineHeight: '1.4',
      padding: '0 8px 0 4px',
      margin: '0',
    },
    '.cm-scroller': { lineHeight: '1.4' },
  });

  function makeEditor(host: HTMLElement, initialCode: string): EditorView {
    const pythonSupport = python();
    return new EditorView({
      doc: initialCode,
      extensions: [
        lineNumbers(),
        highlightActiveLine(),
        history(),
        indentOnInput(),
        bracketMatching(),
        closeBrackets(),
        indentUnit.of('    '),
        syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
        pythonSupport,
        // Built-in Python keyword + builtin completion (print, len, range, ...)
        // and local-symbol completion (functions / variables defined in the
        // user's own code).
        pythonSupport.language.data.of({
          autocomplete: globalCompletion,
        }),
        pythonSupport.language.data.of({
          autocomplete: localCompletionSource,
        }),
        autocompletion({ activateOnTyping: true }),
        oneDark,
        tightLines,
        keymap.of([
          indentWithTab,
          ...closeBracketsKeymap,
          ...completionKeymap,
          ...defaultKeymap,
          ...historyKeymap,
        ]),
        EditorState.tabSize.of(4),
      ],
      parent: host,
    });
  }

  function attachRepl(root: HTMLElement) {
    const runBtn = root.querySelector<HTMLButtonElement>('.pyrepl__run')!;
    const resetBtn = root.querySelector<HTMLButtonElement>('.pyrepl__reset')!;
    const host = root.querySelector<HTMLElement>('[data-editor]')!;
    const output = root.querySelector<HTMLElement>('[data-output]')!;
    const timing = root.querySelector<HTMLElement>('[data-timing]')!;
    const status = root.querySelector<HTMLElement>('[data-status]')!;
    const original = root.dataset.original ?? '';

    const runtimes: number[] = [];
    const view = makeEditor(host, original);

    resetBtn.addEventListener('click', () => {
      view.dispatch({
        changes: { from: 0, to: view.state.doc.length, insert: original },
      });
      output.textContent = '(reset)';
      status.textContent = 'idle';
      timing.textContent = '';
    });

    runBtn.addEventListener('click', async () => {
      runBtn.disabled = true;
      output.textContent = '';
      timing.textContent = '';
      status.textContent = pyodidePromise ? 'running…' : 'loading Python…';

      let stdout = '';
      let stderr = '';
      try {
        const pyodide = await loadPyodideOnce();
        status.textContent = 'running…';
        pyodide.setStdout({ batched: (s: string) => { stdout += s + '\n'; } });
        pyodide.setStderr({ batched: (s: string) => { stderr += s + '\n'; } });

        const code = view.state.doc.toString();
        try {
          const t0 = performance.now();
          await runPythonTimed(pyodide, code);
          const ms = performance.now() - t0;
          runtimes.push(ms);
          const text = (stdout || '(no output)') + (stderr ? `\n--- stderr ---\n${stderr}` : '');
          output.textContent = text;
          status.textContent = stderr ? 'done (with stderr)' : 'done';
          const avg = runtimes.reduce((a, b) => a + b, 0) / runtimes.length;
          timing.textContent = runtimes.length === 1
            ? `Runtime: ${ms.toFixed(1)}ms`
            : `Runtime: ${ms.toFixed(1)}ms  |  avg ${avg.toFixed(1)}ms over ${runtimes.length} runs`;
        } catch (err: any) {
          const msg = err?.message ?? String(err);
          output.textContent = `${stdout}${stderr ? `\n${stderr}` : ''}\n${msg}`;
          status.textContent = msg.includes('Timed out') ? 'timed out' : 'error';
        }
      } catch (err: any) {
        output.textContent = `Failed to load Python runtime: ${err?.message ?? err}`;
        status.textContent = 'load failed';
      } finally {
        runBtn.disabled = false;
      }
    });
  }

  function attachCodeBlockRunner(figure: HTMLElement) {
    const pre = figure.querySelector<HTMLElement>('pre[data-language="python"]');
    if (!pre) return;

    const toolbar = document.createElement('div');
    toolbar.className = 'code-run-toolbar';

    const runBtn = document.createElement('button');
    runBtn.className = 'code-run-btn';
    runBtn.textContent = '▶ Run';
    toolbar.append(runBtn);

    const statusEl = document.createElement('span');
    statusEl.className = 'code-run-status';
    toolbar.append(statusEl);

    const wrapper = document.createElement('div');
    wrapper.className = 'code-run-output';
    wrapper.hidden = true;
    const outputEl = document.createElement('pre');
    outputEl.className = 'code-run-output__text';
    const timingEl = document.createElement('div');
    timingEl.className = 'code-run-output__timing';
    wrapper.append(outputEl, timingEl);

    // Insert toolbar above the EC block, output below
    const ec = figure.closest('.expressive-code') ?? figure;
    ec.before(toolbar);
    ec.after(wrapper);

    const runtimes: number[] = [];

    runBtn.addEventListener('click', async () => {
      // Append test harness from the page's REPL scaffold so execution times are meaningful
      const scaffold = document.querySelector<HTMLElement>('[data-original]')?.dataset.original ?? '';
      const testSnippet = scaffold.match(/\ndef _run_tests[\s\S]*/)?.[0]?.trim() ?? '';
      const code = pre.innerText + (testSnippet ? '\n\n' + testSnippet : '');
      runBtn.disabled = true;
      statusEl.textContent = pyodidePromise ? 'running…' : 'loading Python…';
      outputEl.textContent = '';
      timingEl.textContent = '';
      wrapper.hidden = false;

      let stdout = '';
      let stderr = '';
      try {
        const pyodide = await loadPyodideOnce();
        statusEl.textContent = 'running…';
        pyodide.setStdout({ batched: (s: string) => { stdout += s + '\n'; } });
        pyodide.setStderr({ batched: (s: string) => { stderr += s + '\n'; } });

        try {
          const t0 = performance.now();
          await runPythonTimed(pyodide, code);
          const ms = performance.now() - t0;
          runtimes.push(ms);
          outputEl.textContent = (stdout || '(no output)') + (stderr ? `\n--- stderr ---\n${stderr}` : '');
          statusEl.textContent = stderr ? 'done (with stderr)' : 'done';
          const avg = runtimes.reduce((a, b) => a + b, 0) / runtimes.length;
          timingEl.textContent = runtimes.length === 1
            ? `Runtime: ${ms.toFixed(1)}ms`
            : `Runtime: ${ms.toFixed(1)}ms  |  avg ${avg.toFixed(1)}ms over ${runtimes.length} runs`;
        } catch (err: any) {
          const msg = err?.message ?? String(err);
          outputEl.textContent = `${stdout}${stderr ? `\n${stderr}` : ''}\n${msg}`;
          statusEl.textContent = msg.includes('Timed out') ? 'timed out' : 'error';
        }
      } catch (err: any) {
        outputEl.textContent = `Failed to load Python runtime: ${err?.message ?? err}`;
        statusEl.textContent = 'load failed';
      } finally {
        runBtn.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLElement>('.pyrepl').forEach(attachRepl);
  document.querySelectorAll<HTMLElement>('figure.frame').forEach(attachCodeBlockRunner);
</script>

<style>
  .pyrepl {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    margin: 1.25rem 0;
    overflow: hidden;
    background: var(--sl-color-bg);
  }
  .pyrepl__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .pyrepl__btn-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pyrepl__run, .pyrepl__reset {
    display: flex;
    align-items: center;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text);
    padding: 0.35rem 0.8rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    white-space: nowrap;
  }
  .pyrepl__run {
    background: var(--sl-color-accent, #6750a4);
    color: white;
    border-color: transparent;
  }
  .pyrepl__run:disabled { opacity: 0.6; cursor: wait; }
  .pyrepl__status {
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .pyrepl__editor-host {
    /* CodeMirror styles itself; this just sizes the host. */
    min-height: 280px;
    max-height: 560px;
    overflow: auto;
  }
  .pyrepl__editor-host :global(.cm-editor) {
    height: 100%;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .pyrepl__editor-host :global(.cm-editor.cm-focused) {
    outline: none;
  }
  .pyrepl__editor-host :global(.cm-scroller) {
    line-height: 1.4;
  }
  /* Starlight's content CSS adds vertical margin to direct child elements;
     reset that inside the editor so each .cm-line isn't double-spaced. */
  .pyrepl__editor-host :global(.cm-content),
  .pyrepl__editor-host :global(.cm-content > *),
  .pyrepl__editor-host :global(.cm-line),
  .pyrepl__editor-host :global(.cm-gutter),
  .pyrepl__editor-host :global(.cm-gutterElement) {
    margin: 0;
    padding-top: 0;
    padding-bottom: 0;
  }
  .pyrepl__editor-host :global(.cm-line) {
    padding: 0 4px;
  }
  .pyrepl__editor-host :global(.cm-gutterElement) {
    line-height: 1.4;
  }
  .pyrepl__output {
    margin: 0;
    padding: 0.75rem;
    background: var(--sl-color-black, #0d0d0d);
    color: var(--sl-color-text);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85rem;
    line-height: 1.45;
    border-top: 1px solid var(--sl-color-gray-5);
    max-height: 280px;
    overflow: auto;
    white-space: pre-wrap;
  }
  .pyrepl__timing {
    padding: 0.35rem 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-black, #0d0d0d);
    border-top: 1px solid var(--sl-color-gray-6);
    min-height: 0;
  }
  .pyrepl__timing:empty {
    display: none;
  }
</style>
